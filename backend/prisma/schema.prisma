generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================
// 1. User - 用户表
// ============================
model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  nickname    String?
  role        String    @default("student")
  status      String    @default("enabled")
  teacherId   Int?
  studentId   Int?
  lastLoginAt DateTime?

  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  student     Student?  @relation(fields: [studentId], references: [id])

  notices         Notice[]         @relation("NoticePublisher")
  rewardsPunished RewardPunishment[] @relation("RPLogger")
  logs            OperationLog[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================
// 2. Student - 学生表
// ============================
model Student {
  id             Int      @id @default(autoincrement())
  studentNo      String   @unique
  name           String
  gender         String   @default("unknown")
  birthDate      DateTime?
  phone          String?
  address        String?
  grade          String
  enrollmentDate DateTime @default(now())
  status         String   @default("studying")
  avatar         String?
  remark         String?

  majorId Int
  classId Int

  major Major @relation(fields: [majorId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  users            User[]
  scores           Score[]
  attendance       AttendanceRecord[]
  rewardPunishes   RewardPunishment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 3. Teacher - 教师表
// ============================
model Teacher {
  id            Int      @id @default(autoincrement())
  teacherNo     String   @unique
  name          String
  gender        String   @default("unknown")
  department    String
  title         String?
  phone         String?
  email         String?
  isHeadTeacher Boolean  @default(false)
  remark        String?

  users           User[]
  headClasses     Class[]              @relation("ClassHeadTeacher")
  courses         Course[]
  recordedScores  Score[]              @relation("ScoreRecorder")
  recordedAttend  AttendanceRecord[]   @relation("AttendanceRecorder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 4. Major - 专业表
// ============================
model Major {
  id          Int      @id @default(autoincrement())
  majorNo     String   @unique
  name        String
  department  String
  duration    Int      @default(4)
  description String?
  status      String   @default("enabled")

  classes  Class[]
  students Student[]
  courses  Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 5. Class - 班级表
// ============================
model Class {
  id            Int      @id @default(autoincrement())
  classNo       String   @unique
  name          String
  grade         String
  majorId       Int
  headTeacherId Int?
  status        String   @default("enabled")
  remark        String?

  major       Major    @relation(fields: [majorId], references: [id])
  headTeacher Teacher? @relation("ClassHeadTeacher", fields: [headTeacherId], references: [id])

  students      Student[]
  courseClasses CourseClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 6. Course - 课程表
// ============================
model Course {
  id        Int     @id @default(autoincrement())
  courseNo  String  @unique
  name      String
  type      String  @default("required")
  credit    Float   @default(0)
  teacherId Int
  majorId   Int?
  grade     String
  semester  String
  status    String  @default("enabled")
  remark    String?

  teacher Teacher @relation(fields: [teacherId], references: [id])
  major   Major?  @relation(fields: [majorId], references: [id])

  scores         Score[]
  attendance     AttendanceRecord[]
  courseClasses  CourseClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 7. CourseClass - 课程班级关联表
// ============================
model CourseClass {
  id       Int      @id @default(autoincrement())
  courseId Int
  classId  Int

  course Course @relation(fields: [courseId], references: [id])
  class  Class  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@unique([courseId, classId])
}

// ============================
// 8. Score - 成绩表
// ============================
model Score {
  id         Int    @id @default(autoincrement())
  studentId  Int
  courseId   Int
  semester   String
  usualScore Float  @default(0)
  finalScore Float  @default(0)
  totalScore Float  @default(0)
  level      String @default("fail")
  recorderId Int?
  remark     String?

  student  Student  @relation(fields: [studentId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  recorder Teacher? @relation("ScoreRecorder", fields: [recorderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId, semester])
}

// ============================
// 9. AttendanceRecord - 考勤表
// ============================
model AttendanceRecord {
  id              Int      @id @default(autoincrement())
  studentId       Int
  courseId        Int
  attendanceDate  DateTime
  status          String   @default("normal")
  recorderId      Int?
  remark          String?

  student  Student  @relation(fields: [studentId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  recorder Teacher? @relation("AttendanceRecorder", fields: [recorderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId, attendanceDate])
}

// ============================
// 10. RewardPunishment - 奖惩表
// ============================
model RewardPunishment {
  id             Int      @id @default(autoincrement())
  studentId      Int
  type           String   @default("reward")
  title          String
  level          String?
  recordDate     DateTime @default(now())
  description    String?
  recorderUserId Int?

  student      Student @relation(fields: [studentId], references: [id])
  recorderUser User?   @relation("RPLogger", fields: [recorderUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 11. Notice - 通知公告表
// ============================
model Notice {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  category    String    @default("system")
  status      String    @default("draft")
  isTop       Boolean   @default(false)
  publisherId Int?
  publishedAt DateTime?
  expiredAt   DateTime?
  viewCount   Int       @default(0)

  publisher User? @relation("NoticePublisher", fields: [publisherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================
// 12. OperationLog - 操作日志表
// ============================
model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  username    String?
  role        String?
  module      String
  action      String
  description String?
  result      String   @default("success")
  ip          String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
